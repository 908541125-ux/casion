<script>
// ════════════════════════════════════════════
// ANIMATED BACKGROUND
// ════════════════════════════════════════════
(()=>{
  const c=document.getElementById('bg-canvas'),x=c.getContext('2d');
  const resize=()=>{c.width=innerWidth;c.height=innerHeight;};resize();addEventListener('resize',resize);
  const stars=Array.from({length:140},()=>({x:Math.random(),y:Math.random(),r:.3+Math.random()*1.6,s:.08+Math.random()*.5,p:Math.random()*Math.PI*2}));
  // Shooting stars
  const shots=[];
  const loop=()=>{
    x.clearRect(0,0,c.width,c.height);
    const t=Date.now()/1000;
    stars.forEach(s=>{const a=Math.sin(t*s.s+s.p)*.42+.58;x.beginPath();x.arc(s.x*c.width,s.y*c.height,s.r*a,0,Math.PI*2);x.fillStyle=`rgba(255,215,0,${.25*a})`;x.fill();});
    // Shooting stars
    if(Math.random()<.003)shots.push({x:Math.random(),y:0,vx:.008+Math.random()*.012,vy:.004+Math.random()*.008,life:1});
    for(let i=shots.length-1;i>=0;i--){const s=shots[i];s.x+=s.vx;s.y+=s.vy;s.life-=.012;if(s.life<=0||s.x>1||s.y>1){shots.splice(i,1);continue;}const gx=c.createLinearGradient(s.x*c.width,s.y*c.height,(s.x-s.vx*12)*c.width,(s.y-s.vy*12)*c.height);gx.addColorStop(0,`rgba(255,255,255,${s.life})`);gx.addColorStop(1,'transparent');x.strokeStyle=gx;x.lineWidth=1.5;x.beginPath();x.moveTo(s.x*c.width,s.y*c.height);x.lineTo((s.x-s.vx*12)*c.width,(s.y-s.vy*12)*c.height);x.stroke();}
    // Ambient orbs
    for(let i=0;i<3;i++){const ox=c.width*(.2+i*.3)+Math.sin(t*.18+i)*55,oy=c.height*.5+Math.cos(t*.13+i*2)*80;const g=x.createRadialGradient(ox,oy,0,ox,oy,200);g.addColorStop(0,'rgba(255,215,0,0.018)');g.addColorStop(1,'transparent');x.fillStyle=g;x.fillRect(0,0,c.width,c.height);}
    requestAnimationFrame(loop);
  };loop();
})();

