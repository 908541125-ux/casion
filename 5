function initRoulette(area){
  let bet=10,selBet=null,spinning=false,wAngle=0,af=null;
  area.innerHTML=`<div class="roulette-wrap"><div class="wheel-outer"><div class="wheel-arrow">▼</div><canvas id="rwc" width="210" height="210" style="border-radius:50%;position:relative;z-index:1;box-shadow:0 0 35px rgba(255,215,0,.18)"></canvas></div><div class="msg-box msg-neutral" id="rm">Choose a bet, then spin!</div><div id="rbb"></div><div class="r-bet-grid"><div class="r-btn rb" data-b="red">🔴 Red (2×)</div><div class="r-btn bk" data-b="black">⚫ Black (2×)</div><div class="r-btn" data-b="green">🟢 Zero (35×)</div><div class="r-btn" data-b="odd">Odd (2×)</div><div class="r-btn" data-b="even">Even (2×)</div><div class="r-btn" data-b="low">1–18 (2×)</div><div class="r-btn" data-b="high">19–36 (2×)</div><div class="r-btn" data-b="dozen1">1st 12 (3×)</div><div class="r-btn" data-b="dozen2">2nd 12 (3×)</div></div><div class="r-num-grid" id="rng"></div><button class="btn btn-gold" id="rspin" style="margin-top:6px;letter-spacing:3px">✦ SPIN THE WHEEL ✦</button></div>`;
  area.querySelector('#rbb').appendChild(betBar(bet,1,50000,v=>bet=v));
  const rng=area.querySelector('#rng');for(let n=0;n<=36;n++){const b=document.createElement('div');b.className='rn';b.textContent=n;b.style.background=n===0?'rgba(0,160,60,.28)':isRed(n)?'rgba(192,57,43,.28)':'rgba(8,8,8,.5)';b.dataset.b='num-'+n;rng.appendChild(b);}
  area.querySelectorAll('[data-b]').forEach(b=>b.onclick=()=>{area.querySelectorAll('[data-b]').forEach(x=>x.classList.remove('sel'));b.classList.add('sel');selBet=b.dataset.b;});
  const nums=[0,32,15,19,4,21,2,25,17,34,6,27,13,36,11,30,8,23,10,5,24,16,33,1,20,14,31,9,22,18,29,7,28,12,35,3,26];
  const cv=area.querySelector('#rwc'),ctx=cv.getContext('2d');
