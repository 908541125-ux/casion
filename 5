  if(coins<loanDebt){toast(`Not enough coins! You need 🪙${loanDebt}. You have 🪙${coins}.`);closeSharkModal();return;}
  coins-=loanDebt;
  const paid=loanDebt;
  loanDebt=0;loanAmount=0;
