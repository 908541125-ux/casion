  inp.addEventListener('keydown',e=>{if(e.key===' '||e.key==='Enter'){e.preventDefault();const idx=words.findIndex(w=>w.word===input);if(idx>=0){const w=words[idx];earned=Math.min(earned+Math.ceil(12+(H-w.y)/H*12),120);score++;words.splice(idx,1);}input='';inp.value='';}if(over&&(e.key===' '||e.key==='Enter')){e.preventDefault();words=[];lives=3;score=0;earned=0;over=false;}});
  function spawn(){words.push({word:WORDS[Math.floor(Math.random()*WORDS.length)],x:35+Math.random()*(W-120),y:102,speed:.55+Math.random()*.75+score*.035});}
  function loop(){ctx.fillStyle='#080820';ctx.fillRect(0,0,W,H);for(let i=0;i<18;i++){const a=Math.sin(Date.now()/1500+i)*.3+.3;ctx.fillStyle=`rgba(147,112,219,${a*.15})`;ctx.fillRect((i*127)%W,(i*83)%H,2,2);}mgHeader(ctx,W,earned,'Type words + Space · Lives: '+'❤️'.repeat(lives)+'🖤'.repeat(Math.max(0,3-lives)));if(!over){frame++;if(frame%Math.max(55-score*3,25)===0)spawn();for(let i=words.length-1;i>=0;i--){const w=words[i];w.y+=w.speed;ctx.font='bold 15px Nunito';const isMatch=w.word.startsWith(input)&&input.length>0;const tw=ctx.measureText(w.word).width;ctx.fillStyle=isMatch?'rgba(255,215,0,.14)':'rgba(255,255,255,.05)';ctx.beginPath();if(ctx.roundRect)ctx.roundRect(w.x-5,w.y-20,tw+10,24,5);else ctx.rect(w.x-5,w.y-20,tw+10,24);ctx.fill();ctx.fillStyle=isMatch?'#FFD700':'rgba(255,255,255,.88)';ctx.textAlign='left';ctx.fillText(w.word,w.x,w.y);if(isMatch&&input.length>0){const pw=ctx.measureText(input).width;ctx.fillStyle='rgba(255,215,0,.5)';ctx.fillRect(w.x,w.y+2,pw,2);}if(w.y>H-55){lives--;words.splice(i,1);if(lives<=0)over=true;}}ctx.fillStyle='rgba(0,0,0,.5)';ctx.beginPath();if(ctx.roundRect)ctx.roundRect(W/2-110,H-58,220,34,8);else ctx.rect(W/2-110,H-58,220,34);ctx.fill();ctx.strokeStyle='rgba(255,215,0,.22)';ctx.lineWidth=1;ctx.beginPath();if(ctx.roundRect)ctx.roundRect(W/2-110,H-58,220,34,8);else ctx.rect(W/2-110,H-58,220,34);ctx.stroke();ctx.fillStyle=input?'#FFD700':'rgba(255,255,255,.25)';ctx.font='bold 15px Nunito';ctx.textAlign='center';ctx.fillText(input?'> '+input+' <':'start typing...',W/2,H-35);}else{ctx.fillStyle='rgba(0,0,0,.75)';ctx.fillRect(0,98,W,H-98);ctx.fillStyle='#e74c3c';ctx.font='bold 28px Cinzel';ctx.textAlign='center';ctx.fillText('GAME OVER',W/2,H/2-28);ctx.fillStyle='#FFD700';ctx.font='bold 16px Nunito';ctx.fillText('Earned: 🪙'+earned+' · Words: '+score,W/2,H/2+12);ctx.fillStyle='rgba(255,255,255,.4)';ctx.font='13px Cinzel';ctx.fillText('Click or Space to restart',W/2,H/2+46);}mgReturnBtn(ctx,W,H,earned);activeLoop=requestAnimationFrame(loop);}
  loop();
}


// ════════════════════════════════════════════
// MG6: RUN FROM TONY
// ════════════════════════════════════════════
function initRun(area){
  stopLoop();
  const W=480,H=430;
  area.innerHTML=`<canvas id="mgrun" class="mg-canvas" width="${W}" height="${H}" tabindex="0"></canvas><div class="mg-info">← → to run · ↑ / Space to jump · Double-jump! Reach the EXIT to escape!</div>`;
  const cv=area.querySelector('#mgrun'),ctx=cv.getContext('2d');
  setTimeout(()=>cv.focus(),100);

  // All positions are in SCREEN space. The world scrolls left automatically.
  // Player stays near left third of screen. Tony chases from the left edge.
  const GROUND=H-58;
  const PW=24,PH=36;
  const GOAL=4000; // distance in pixels to reach exit

  // --- STATE ---
  let scrollX=0;        // total world scroll (increases as player runs)
  let playerX=120;      // player screen X (can move left/right within bounds)
  let playerY=GROUND-PH;
  let pvx=0,pvy=0,onGround=true,jumpsLeft=2;
  let baseScroll=2.5;   // auto-scroll speed
  let frame=0,tFrame=0;
  let gameOver=false,won=false,earned=0;
  let screenShake=0;
  let particles=[];

  // Tony: starts off left edge, gradually closes in
  let tonyScreenX=-120;  // screen X (left of screen = behind player)
  let tonyY=GROUND-58;
  let tonyActive=false;

  // Obstacles in screen coords (spawned ahead, scroll left with world)
  let obstacles=[]; // {x,y,w,h,type}
  let coins=[];     // {x,y,bob,taken}
  let goons=[];     // {x,y,angry,legPhase}
  let exitX=W+200;  // exit portal screen X (stays far right, player must reach it)
  let exitReached=false;

  function spawnObstacle(){
    const types=['barrel','crate','hydrant','spike'];
    const t=types[Math.floor(Math.random()*types.length)];
    const h=t==='spike'?18:t==='hydrant'?32:26;
    const w=t==='spike'?36:26;
    obstacles.push({x:W+60+Math.random()*120,y:GROUND-h,w,h,type:t});
  }
  function spawnCoin(){
    coins.push({x:W+50+Math.random()*200,y:GROUND-PH-15-Math.random()*70,bob:Math.random()*Math.PI*2,taken:false});
  }
  function spawnGoon(){
    const angry=scrollX>1500&&Math.random()<.45;
    goons.push({x:W+40+Math.random()*160,y:GROUND-42,angry,legPhase:Math.random()*Math.PI*2});
  }
  function puff(x,y,col,n=6){for(let i=0;i<n;i++)particles.push({x,y,vx:(Math.random()-.5)*5,vy:-(1+Math.random()*3),life:1,size:4+Math.random()*6,col,text:null});}
  function coinPop(x,y){for(let i=0;i<6;i++)particles.push({x,y,vx:(Math.random()-.5)*5,vy:-(2+Math.random()*3),life:1,size:5,col:'#FFD700',text:'🪙'});}

  // Pre-spawn some content
  for(let i=0;i<3;i++)spawnObstacle();
  for(let i=0;i<5;i++)spawnCoin();
  for(let i=0;i<3;i++)spawnGoon();

  function resetGame(){
    scrollX=0;playerX=120;playerY=GROUND-PH;pvx=0;pvy=0;onGround=true;jumpsLeft=2;
    baseScroll=2.5;frame=0;tFrame=0;gameOver=false;won=false;earned=0;screenShake=0;
    particles=[];obstacles=[];coins=[];goons=[];
    tonyScreenX=-120;tonyActive=false;exitX=W+200;exitReached=false;
    for(let i=0;i<3;i++)spawnObstacle();
    for(let i=0;i<5;i++)spawnCoin();
    for(let i=0;i<3;i++)spawnGoon();
  }

  const keys={};
  const kd=e=>{
    keys[e.code]=true;
    if(['ArrowLeft','ArrowRight','ArrowUp','Space'].includes(e.code))e.preventDefault();
    if((e.code==='ArrowUp'||e.code==='Space')&&jumpsLeft>0&&!gameOver&&!won){
      pvy=-14;jumpsLeft--;
      puff(playerX+PW/2,playerY,'#aaddff',4);
    }
  };
  const ku=e=>delete keys[e.code];
  document.addEventListener('keydown',kd);
  document.addEventListener('keyup',ku);

  cv.addEventListener('click',e=>{
    const r=cv.getBoundingClientRect();
    const cx2=(e.clientX-r.left)*(W/r.width);
    const cy2=(e.clientY-r.top)*(H/r.height);
    if(won&&cy2>H-52&&cy2<H-20){
      if(window._savingCasino)casinoSaved(earned);
      else{window.coins+=earned;updateHUD();toast('+\uD83E\uDE99'+earned+' earned!');stopLoop();closeGame();}
      return;
    }
    if(gameOver){
      if(window._savingCasino)casinoLost();
      else resetGame();
    }
  });

  function drawPlayer(x,y){
    const rc=Math.sin(frame*0.35)*9;
    ctx.save();ctx.translate(x,y);
    // shadow
    ctx.fillStyle='rgba(0,0,0,0.25)';ctx.beginPath();ctx.ellipse(PW/2,PH+3,13,4,0,0,Math.PI*2);ctx.fill();
    // legs
    ctx.fillStyle='#2244aa';ctx.fillRect(3,PH-12+rc,9,15);ctx.fillRect(13,PH-12-rc,9,15);
    // body
    const bg=ctx.createLinearGradient(0,0,PW,0);bg.addColorStop(0,'#4477ff');bg.addColorStop(1,'#2244cc');
    ctx.fillStyle=bg;ctx.beginPath();if(ctx.roundRect)ctx.roundRect(1,PH-28,PW-2,17,4);else ctx.fillRect(1,PH-28,PW-2,17);ctx.fill();
    // briefcase arm
    ctx.fillStyle='#2244aa';ctx.fillRect(-5,PH-26,7,11);
    ctx.fillStyle='#8B6914';ctx.beginPath();if(ctx.roundRect)ctx.roundRect(-13,PH-24,11,15,3);else ctx.rect(-13,PH-24,11,15);ctx.fill();
    ctx.fillStyle='rgba(255,215,0,0.5)';ctx.fillRect(-10,PH-17,5,2);
    // head
    ctx.fillStyle='#e8c99a';ctx.beginPath();ctx.arc(PW/2,PH-36,10,0,Math.PI*2);ctx.fill();
    // hair
    ctx.fillStyle='#4a2800';ctx.fillRect(2,PH-46,PW-4,7);
    // eyes scared
    ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(PW/2-4,PH-38,3,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.arc(PW/2+4,PH-38,3,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#222';ctx.beginPath();ctx.arc(PW/2-4,PH-38,1.8,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.arc(PW/2+4,PH-38,1.8,0,Math.PI*2);ctx.fill();
    // sweat
    ctx.fillStyle='rgba(100,180,255,0.8)';ctx.beginPath();ctx.arc(PW+2,PH-42,2.5,0,Math.PI*2);ctx.fill();
    ctx.restore();
  }

  function drawTony(x,y){
    const tls=Math.sin(tFrame*0.45)*11;
    ctx.save();ctx.translate(x,y);
    // shadow
    ctx.fillStyle='rgba(255,0,0,0.18)';ctx.beginPath();ctx.ellipse(0,58,28,7,0,0,Math.PI*2);ctx.fill();
    // legs
    ctx.fillStyle='#111';ctx.fillRect(-18,54+tls,15,26);ctx.fillRect(3,54-tls,15,26);
    // suit
    const tb=ctx.createLinearGradient(-22,0,22,0);tb.addColorStop(0,'#1a0a00');tb.addColorStop(1,'#3a1a00');
    ctx.fillStyle=tb;ctx.beginPath();if(ctx.roundRect)ctx.roundRect(-22,2,44,52,5);else ctx.fillRect(-22,2,44,52);ctx.fill();
    // pinstripes
    ctx.strokeStyle='rgba(255,215,0,0.15)';ctx.lineWidth=1;
    for(let s=0;s<4;s++){ctx.beginPath();ctx.moveTo(-18+s*12,2);ctx.lineTo(-18+s*12,54);ctx.stroke();}
    // shirt & tie
    ctx.fillStyle='#f0e8d0';ctx.fillRect(-7,4,14,28);
    ctx.fillStyle='#cc0000';ctx.beginPath();ctx.moveTo(-4,6);ctx.lineTo(0,30);ctx.lineTo(4,6);ctx.fill();
    // head
    ctx.fillStyle='#d4a060';ctx.beginPath();ctx.arc(0,-10,21,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#c89050';ctx.beginPath();ctx.ellipse(0,9,13,7,0,0,Math.PI*2);ctx.fill();
    // eyes menacing
    ctx.fillStyle='#111';ctx.beginPath();ctx.arc(-8,-14,4,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.arc(8,-14,4,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#ff0000';ctx.beginPath();ctx.arc(-8,-14,2,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.arc(8,-14,2,0,Math.PI*2);ctx.fill();
    // scar
    ctx.strokeStyle='#8B0000';ctx.lineWidth=2;ctx.beginPath();ctx.moveTo(6,-20);ctx.lineTo(12,-10);ctx.stroke();
    // hat
    ctx.fillStyle='#111';ctx.fillRect(-20,-34,40,11);ctx.beginPath();if(ctx.roundRect)ctx.roundRect(-13,-46,26,13,3);else ctx.fillRect(-13,-46,26,13);ctx.fill();
    ctx.fillStyle='rgba(255,215,0,0.6)';ctx.fillRect(-20,-24,40,3);
    // cigar
    ctx.fillStyle='#c8a060';ctx.fillRect(8,-6,16,4);ctx.fillStyle='#ff6600';ctx.beginPath();ctx.arc(24,-4,4,0,Math.PI*2);ctx.fill();
    // speech bubble if close
    if(x>-60&&x<playerX+100){
      const lines=["PAY UP!","YOU CAN'T RUN!","GOTCHA!","COME HERE!"];
      const lbl=lines[Math.floor(tFrame/70)%lines.length];
      ctx.font='bold 11px Nunito';const tw2=ctx.measureText(lbl).width+16;
      ctx.fillStyle='rgba(255,220,50,0.95)';ctx.strokeStyle='#cc0000';ctx.lineWidth=2;
      ctx.beginPath();if(ctx.roundRect)ctx.roundRect(-tw2/2,-68,tw2,22,7);else ctx.rect(-tw2/2,-68,tw2,22);ctx.fill();ctx.stroke();
      ctx.fillStyle='#8B0000';ctx.textAlign='center';ctx.fillText(lbl,0,-51);
    }
    ctx.restore();
  }

  function drawGoon(g){
    const lp=Math.sin(tFrame*0.4+g.legPhase)*10;
    ctx.save();ctx.translate(g.x,g.y);
    ctx.fillStyle='rgba(0,0,0,0.2)';ctx.beginPath();ctx.ellipse(0,44,14,4,0,0,Math.PI*2);ctx.fill();
    // legs
    ctx.fillStyle=g.angry?'#3a0000':'#111';ctx.fillRect(-11,26+lp,9,18);ctx.fillRect(2,26-lp,9,18);
    // body
    const bg2=ctx.createLinearGradient(-13,0,13,0);bg2.addColorStop(0,g.angry?'#8B0000':'#2c1810');bg2.addColorStop(1,g.angry?'#cc0000':'#4a2c1a');
    ctx.fillStyle=bg2;ctx.beginPath();if(ctx.roundRect)ctx.roundRect(-13,2,26,26,3);else ctx.fillRect(-13,2,26,26);ctx.fill();
    ctx.fillStyle=g.angry?'#ff0000':'#cc0000';ctx.beginPath();ctx.moveTo(-3,4);ctx.lineTo(0,16);ctx.lineTo(3,4);ctx.fill();
    // head
    ctx.fillStyle='#d4a882';ctx.beginPath();ctx.arc(0,-6,13,0,Math.PI*2);ctx.fill();
    ctx.fillStyle=g.angry?'#ff2200':'#222';ctx.beginPath();ctx.arc(-5,-10,g.angry?3.5:2.5,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.arc(5,-10,g.angry?3.5:2.5,0,Math.PI*2);ctx.fill();
    // hat
    ctx.fillStyle='#111';ctx.fillRect(-12,-20,24,7);ctx.fillRect(-7,-28,14,9);
    if(g.angry){ctx.font='9px serif';ctx.textAlign='center';ctx.fillText('😡',0,-34);}
    ctx.restore();
  }

  function drawObstacle(o){
    ctx.save();
    if(o.type==='barrel'){
      const bg=ctx.createLinearGradient(o.x-13,0,o.x+13,0);bg.addColorStop(0,'#a0522d');bg.addColorStop(1,'#6b3410');
      ctx.fillStyle=bg;ctx.beginPath();if(ctx.roundRect)ctx.roundRect(o.x-13,o.y,26,o.h,5);else ctx.fillRect(o.x-13,o.y,26,o.h);ctx.fill();
      ctx.strokeStyle='#3a1a05';ctx.lineWidth=2;ctx.strokeRect(o.x-13,o.y,26,o.h);
      ctx.font='14px serif';ctx.textAlign='center';ctx.fillText('☢️',o.x,o.y+o.h-4);
    } else if(o.type==='crate'){
      ctx.fillStyle='#8B6914';ctx.fillRect(o.x-13,o.y,26,o.h);
      ctx.strokeStyle='#5a4010';ctx.lineWidth=1.5;ctx.strokeRect(o.x-13,o.y,26,o.h);
      ctx.beginPath();ctx.moveTo(o.x-13,o.y);ctx.lineTo(o.x+13,o.y+o.h);ctx.moveTo(o.x+13,o.y);ctx.lineTo(o.x-13,o.y+o.h);ctx.stroke();
    } else if(o.type==='hydrant'){
      ctx.fillStyle='#cc3300';ctx.beginPath();if(ctx.roundRect)ctx.roundRect(o.x-8,o.y,16,o.h,4);else ctx.rect(o.x-8,o.y,16,o.h);ctx.fill();
      ctx.fillStyle='#ff6600';ctx.beginPath();ctx.arc(o.x,o.y,10,Math.PI,0);ctx.fill();
      ctx.fillStyle='rgba(150,220,255,0.9)';ctx.beginPath();ctx.arc(o.x,o.y-4,5,0,Math.PI*2);ctx.fill();
    } else {
      ctx.fillStyle='#888';for(let s=0;s<4;s++){ctx.beginPath();ctx.moveTo(o.x-14+s*9,GROUND);ctx.lineTo(o.x-10+s*9,GROUND-o.h);ctx.lineTo(o.x-6+s*9,GROUND);ctx.fill();}
    }
    ctx.restore();
  }

  function loop(){
    frame++;tFrame++;
    const scroll=baseScroll+(scrollX/1200);

    if(!gameOver&&!won){
      // Player horizontal movement
      if(keys['ArrowLeft']||keys['KeyA'])pvx=Math.max(pvx-1.1,-6);
      else if(keys['ArrowRight']||keys['KeyD'])pvx=Math.min(pvx+1.1,8);
      else pvx*=0.80;

      // Gravity
      pvy+=0.72;
      playerX+=pvx;
      playerY+=pvy;

      // Bounds
      if(playerX<40)playerX=40;
      if(playerX>W*0.55)playerX=W*0.55;

      // Ground
      if(playerY>=GROUND-PH){playerY=GROUND-PH;pvy=0;onGround=true;jumpsLeft=2;}
      else onGround=false;

      // Scroll world
      scrollX+=scroll;
      baseScroll=Math.min(2.5+scrollX/1500,7);
      earned=Math.floor(scrollX/18);

      // Move all objects left with world scroll + their own velocity
      obstacles.forEach(o=>o.x-=scroll);
      coins.forEach(c=>c.x-=scroll);
      goons.forEach(g=>{
        g.x-=scroll;
        // Goons also drift toward player
        if(g.x>playerX+20)g.x-=0.8+(g.angry?0.8:0);
      });

      // Tony: appears at halfway, marches from left
      if(scrollX>GOAL/2&&!tonyActive){tonyActive=true;tonyScreenX=-80;showWin('🦈 HEIR MILLER IS HERE!');}
      if(tonyActive){
        // Tony moves right toward player, speed increases as player runs
        const catchSpeed=1.2+scrollX/3000;
        tonyScreenX+=catchSpeed;
        if(screenShake>0)screenShake--;
      }

      // Spawn new content as old scrolls off
      if(frame%90===0)spawnGoon();
      if(frame%60===0)spawnCoin();
      if(frame%120===0)spawnObstacle();

      // Culling
      obstacles=obstacles.filter(o=>o.x>-60);
      coins=coins.filter(c=>c.x>-40&&!c.taken);
      goons=goons.filter(g=>g.x>-80);

      // Exit portal moves with world but at a slower rate (so player can reach it)
      // exitX represents screen position of the goal; it drifts in from the right
      exitX-=scroll*0.3;
      if(exitX<W-120)exitX=W-120; // don't let it go too far left

      // Collision: obstacles
      for(const o of obstacles){
        const left=o.x-o.w/2,right=o.x+o.w/2;
        const top=o.y,bot=o.y+o.h;
        if(playerX+PW>left+3&&playerX<right-3&&playerY+PH>top+4&&playerY<bot){
          if(playerY+PH<top+16&&pvy>=0){playerY=top-PH;pvy=0;onGround=true;jumpsLeft=2;}
          else{gameOver=true;screenShake=18;puff(playerX,playerY,'#ff8800',10);}
        }
      }

      // Collision: goons
      for(const g of goons){
        if(Math.abs(g.x-playerX-PW/2)<28&&Math.abs(g.y-playerY-PH/2)<34){
          gameOver=true;screenShake=20;puff(playerX,playerY,'#ff4444',12);
        }
      }

      // Tony collision
      if(tonyActive&&tonyScreenX>playerX-40&&tonyScreenX<playerX+PW+20&&Math.abs(tonyY-playerY)<50){
        gameOver=true;screenShake=30;puff(playerX,playerY,'#ff0000',18);
      }

      // Coin pickup
      for(const c of coins){
        if(!c.taken&&Math.abs(c.x-playerX-PW/2)<28&&Math.abs(c.y-playerY-PH/2)<28){
          c.taken=true;earned+=10;coinPop(c.x,c.y);
        }
      }

      // Win: player reaches exit
      if(exitX<=playerX+PW&&!exitReached){
        exitReached=true;won=true;
        earned=Math.min(earned+80,300);
        cBurst(area,22,'#00ff88');showWin('🏃 ESCAPED HEIR MILLER! 🎉');
      }
    }

    // Particles
    particles=particles.filter(p=>{
      p.x+=p.vx;p.y+=p.vy;p.vy+=0.15;p.life-=0.035;return p.life>0;
    });

    // ── DRAW ──
    const shx=screenShake>0?(Math.random()-.5)*screenShake*0.6:0;
    const shy=screenShake>0?(Math.random()-.5)*screenShake*0.3:0;
    ctx.save();ctx.translate(shx,shy);

    // Sky
    const sky=ctx.createLinearGradient(0,0,0,H);sky.addColorStop(0,'#04000f');sky.addColorStop(1,'#120028');
    ctx.fillStyle=sky;ctx.fillRect(0,0,W,H);

    // Parallax stars
    for(let i=0;i<28;i++){const sx=((i*179-scrollX*0.04)%W+W)%W;const sy=8+((i*83)%60);const tw=Math.sin(frame*0.05+i)*.5+.5;ctx.fillStyle=`rgba(255,220,255,${0.15+tw*0.3})`;ctx.fillRect(sx,sy,1.5,1.5);}

    // Far buildings parallax
    ctx.fillStyle='rgba(80,0,120,0.25)';
    for(let i=0;i<10;i++){const bx=((i*110-scrollX*0.12)%W+W)%W;const bh=40+((i*41)%80);ctx.fillRect(bx,GROUND-bh-15,34+((i*19)%26),bh+15);}

    // Mid buildings parallax
    ctx.fillStyle='rgba(20,0,40,0.8)';
    for(let i=0;i<7;i++){const bx=((i*140-scrollX*0.35)%W+W)%W;const bh=65+((i*53)%90);ctx.fillRect(bx,GROUND-bh,46+((i*23)%28),bh);}

    // Ground
    const gGrad=ctx.createLinearGradient(0,GROUND,0,H);gGrad.addColorStop(0,'#1a0a2e');gGrad.addColorStop(1,'#0d0618');
    ctx.fillStyle=gGrad;ctx.fillRect(0,GROUND,W,H-GROUND);
    // Road dashes
    ctx.strokeStyle='rgba(255,215,0,0.15)';ctx.lineWidth=2;ctx.setLineDash([20,16]);
    const dashOff=(scrollX*0.8)%36;
    ctx.beginPath();ctx.moveTo(-dashOff,GROUND+18);ctx.lineTo(W,GROUND+18);ctx.stroke();ctx.setLineDash([]);
    ctx.fillStyle='rgba(255,255,255,0.05)';ctx.fillRect(0,GROUND,W,3);

    mgHeader(ctx,W,Math.min(earned,300),'← → run  ↑/Space double-jump  · reach the EXIT!');

    // Exit portal
    const ep=Math.sin(tFrame*0.07)*0.3+0.7;
    const eGrad=ctx.createRadialGradient(exitX,GROUND-48,4,exitX,GROUND-48,52);
    eGrad.addColorStop(0,`rgba(0,255,100,${ep})`);eGrad.addColorStop(1,'rgba(0,80,30,0)');
    ctx.fillStyle=eGrad;ctx.beginPath();ctx.arc(exitX,GROUND-48,52,0,Math.PI*2);ctx.fill();
    ctx.strokeStyle=`rgba(0,255,100,${ep})`;ctx.lineWidth=3;ctx.strokeRect(exitX-16,GROUND-78,32,78);
    ctx.fillStyle='#00ff44';ctx.shadowColor='#00ff44';ctx.shadowBlur=14;ctx.font='bold 11px Cinzel';ctx.textAlign='center';ctx.fillText('EXIT',exitX,GROUND-82);ctx.fillText('🚪',exitX,GROUND-52);ctx.shadowBlur=0;

    // Obstacles
    obstacles.forEach(o=>drawObstacle(o));

    // Coins
    coins.filter(c=>!c.taken).forEach(c=>{
      const bob=Math.sin(tFrame*0.09+c.bob)*5;
      ctx.save();ctx.shadowColor='#FFD700';ctx.shadowBlur=12;ctx.font='18px serif';ctx.textAlign='center';ctx.fillText('🪙',c.x,c.y+bob);ctx.restore();
    });

    // Goons
    goons.forEach(g=>drawGoon(g));

    // Tony
    if(tonyActive)drawTony(tonyScreenX,tonyY);

    // Red vignette danger from Tony
    if(tonyActive){
      const danger=Math.max(0,1-(playerX-tonyScreenX)/280);
      if(danger>0){ctx.fillStyle=`rgba(200,0,0,${danger*0.22})`;ctx.fillRect(0,0,W,H);}
    }

    // Player
    if(!gameOver)drawPlayer(playerX,playerY);

    // Particles (screen space)
    particles.forEach(p=>{
      ctx.globalAlpha=Math.max(0,p.life);
      if(p.text){ctx.font='14px serif';ctx.textAlign='center';ctx.fillText(p.text,p.x,p.y);}
      else{ctx.fillStyle=p.col;ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,Math.PI*2);ctx.fill();}
    });
    ctx.globalAlpha=1;

    // Progress bar
    const pct=Math.min(1,scrollX/GOAL);
    ctx.fillStyle='rgba(0,0,0,0.5)';ctx.beginPath();if(ctx.roundRect)ctx.roundRect(14,103,W-28,9,5);else ctx.rect(14,103,W-28,9);ctx.fill();
    const dg=ctx.createLinearGradient(14,0,W-14,0);dg.addColorStop(0,'#ff2200');dg.addColorStop(0.5,'#ff8800');dg.addColorStop(1,'#00ff44');
    ctx.fillStyle=dg;ctx.beginPath();if(ctx.roundRect)ctx.roundRect(14,103,(W-28)*pct,9,5);else ctx.rect(14,103,(W-28)*pct,9);ctx.fill();
    if(tonyActive){const tp=Math.min(1,Math.max(0,tonyScreenX/W));ctx.font='14px serif';ctx.textAlign='center';ctx.fillText('🦈',14+(W-28)*tp,102);}
    ctx.fillStyle='#fff';ctx.font='12px serif';ctx.textAlign='center';ctx.fillText('🏃',14+(W-28)*pct,102);
    ctx.fillStyle='rgba(255,255,255,0.4)';ctx.font='9px Cinzel';ctx.fillText(Math.floor(scrollX)+'m / '+GOAL+'m',W/2,100);

    // Overlays
    if(gameOver){
      ctx.fillStyle='rgba(0,0,0,0.85)';ctx.fillRect(0,0,W,H);
      ctx.fillStyle='#ff3333';ctx.shadowColor='#ff0000';ctx.shadowBlur=20;ctx.font='bold 34px Cinzel';ctx.textAlign='center';ctx.fillText('CAUGHT!',W/2,H/2-50);ctx.shadowBlur=0;
      if(window._savingCasino){
        ctx.fillStyle='rgba(255,120,60,0.9)';ctx.font='15px Nunito';ctx.fillText('The casino is lost...',W/2,H/2-14);
        ctx.fillStyle='rgba(255,200,100,0.8)';ctx.font='bold 13px Cinzel';ctx.fillText('Click to rebuild from scratch',W/2,H/2+22);
      } else {
        ctx.fillStyle='rgba(255,255,255,0.75)';ctx.font='15px Nunito';ctx.fillText("Jeremy's boys got you!",W/2,H/2-14);
        ctx.fillStyle='#FFD700';ctx.font='bold 16px Nunito';ctx.fillText('Earned: \uD83E\uDE99'+earned,W/2,H/2+22);
        ctx.fillStyle='rgba(255,255,255,0.35)';ctx.font='13px Cinzel';ctx.fillText('Click to try again',W/2,H/2+58);
      }
    }
    if(won){
      ctx.fillStyle='rgba(0,15,0,0.9)';ctx.fillRect(0,0,W,H);
      ctx.fillStyle='#00ff88';ctx.shadowColor='#00ff44';ctx.shadowBlur=28;ctx.font='bold 34px Cinzel';ctx.textAlign='center';ctx.fillText('ESCAPED!',W/2,H/2-50);ctx.shadowBlur=0;
      if(window._savingCasino){
        ctx.fillStyle='rgba(255,255,255,0.9)';ctx.font='15px Nunito';ctx.fillText('Casino saved! You outran Jeremy! 🎉',W/2,H/2-12);
        ctx.fillStyle='#FFD700';ctx.font='bold 17px Nunito';ctx.fillText('Reward: \uD83E\uDE99'+earned,W/2,H/2+24);
        const pulse=Math.sin(Date.now()/400)*.1+.9;
        ctx.fillStyle=`rgba(16,185,129,${pulse})`;ctx.beginPath();if(ctx.roundRect)ctx.roundRect(W/2-110,H-46,220,30,8);else ctx.rect(W/2-110,H-46,220,30);ctx.fill();
        ctx.fillStyle='#fff';ctx.font='bold 12px Cinzel';ctx.fillText('CLAIM REWARD & RETURN 🏆',W/2,H-25);
      } else {
        ctx.fillStyle='rgba(255,255,255,0.8)';ctx.font='15px Nunito';ctx.fillText('You outran Jeremy! 🎉',W/2,H/2-12);
        ctx.fillStyle='#FFD700';ctx.font='bold 17px Nunito';ctx.fillText('Total: \uD83E\uDE99'+earned,W/2,H/2+24);
        mgReturnBtn(ctx,W,H,earned);
      }
    }

    ctx.restore();
    activeLoop=requestAnimationFrame(loop);
  }

  area._cleanup=()=>{document.removeEventListener('keydown',kd);document.removeEventListener('keyup',ku);};
  loop();
}

// ════════════════════════════════════════════
// MG7: FIGHT THE FIRE
// ════════════════════════════════════════════
function initFireFight(area){
  stopLoop();
  const W=480,H=430;
  area.innerHTML=`<canvas id="mgff" class="mg-canvas" width="${W}" height="${H}" tabindex="0"></canvas><div class="mg-info">← → move · Hold mouse button to spray water at fires! Put them ALL out!</div>`;
  const cv=area.querySelector('#mgff'),ctx=cv.getContext('2d');
  setTimeout(()=>cv.focus(),100);

  const GROUND=H-55;
  const BLDG_LEFT=30,BLDG_RIGHT=W-30,BLDG_TOP=100;
  const FLOORS=3,FLOOR_H=80;

  let px=W/2,pvx=0;
  let mouseX=W/2,mouseY=H/2,spraying=false;
  let earned=0,frame=0,gameWon=false,gameOver=false;
  let waterParticles=[],steamParticles=[],ashParticles=[];
  let firespots=[],firePool=[];
  let hp=100,water=100; // water tank
  let score=0;

  function spawnFirespots(){
    firespots=[];
    const spots=[
      {x:80, floor:0,intensity:1.0},{x:200,floor:0,intensity:1.3},
      {x:340,floor:0,intensity:0.8},{x:430,floor:0,intensity:1.1},
      {x:110,floor:1,intensity:1.5},{x:250,floor:1,intensity:1.0},
      {x:370,floor:1,intensity:1.2},
      {x:150,floor:2,intensity:0.9},{x:290,floor:2,intensity:1.4},
    ];
    spots.forEach(s=>{
      const fy=BLDG_TOP+(FLOORS-1-s.floor)*FLOOR_H+5;
      firespots.push({x:s.x-22,y:fy,w:44,h:50,intensity:s.intensity,health:100,out:false,floor:s.floor});
    });
    firePool=firespots.map(()=>[]);
  }
  spawnFirespots();

  const keys={};
  const kd=e=>{keys[e.code]=true;if(['ArrowLeft','ArrowRight'].includes(e.code))e.preventDefault();};
  const ku=e=>delete keys[e.code];
  document.addEventListener('keydown',kd);
  document.addEventListener('keyup',ku);
  cv.addEventListener('mousemove',e=>{const r=cv.getBoundingClientRect();mouseX=(e.clientX-r.left)*(W/r.width);mouseY=(e.clientY-r.top)*(H/r.height);});
  cv.addEventListener('mousedown',()=>spraying=true);
  cv.addEventListener('mouseup',()=>spraying=false);
  cv.addEventListener('touchstart',e=>{e.preventDefault();const r=cv.getBoundingClientRect();const t=e.touches[0];mouseX=(t.clientX-r.left)*(W/r.width);mouseY=(t.clientY-r.top)*(H/r.height);spraying=true;},{passive:false});
  cv.addEventListener('touchmove',e=>{e.preventDefault();const r=cv.getBoundingClientRect();const t=e.touches[0];mouseX=(t.clientX-r.left)*(W/r.width);mouseY=(t.clientY-r.top)*(H/r.height);},{passive:false});
  cv.addEventListener('touchend',()=>spraying=false);

  cv.addEventListener('click',e=>{
    const r=cv.getBoundingClientRect();const cy=(e.clientY-r.top)*(H/r.height);
    if(gameWon&&cy>H-52&&cy<H-20){
      if(window._savingCasino){casinoSaved(earned);}
      else{coins+=earned;updateHUD();toast('+\uD83E\uDE99'+earned+' earned!');stopLoop();closeGame();}
      return;
    }
    if(gameOver){
      if(window._savingCasino){casinoLost();}
      else{px=W/2;pvx=0;hp=100;water=100;earned=0;gameOver=false;gameWon=false;frame=0;waterParticles=[];steamParticles=[];ashParticles=[];spawnFirespots();}
    }
  });

  function spawnFirePart(spot){
    if(spot.out)return;
    const si=firespots.indexOf(spot);
    firePool[si].push({
      x:spot.x+spot.w/2+(Math.random()-.5)*spot.w*.7,
      y:spot.y+spot.h*.9,
      vx:(Math.random()-.5)*1.8,vy:-(1.8+Math.random()*3)*spot.intensity,
      life:1,size:7+Math.random()*14,hue:Math.random()<.5?18:38
    });
  }
  function spawnSteam(x,y,n=3){for(let i=0;i<n;i++)steamParticles.push({x,y,vx:(Math.random()-.5)*2.5,vy:-(0.6+Math.random()*2),life:1,size:12+Math.random()*18});}
  function spawnAsh(x,y){for(let i=0;i<5;i++)ashParticles.push({x,y,vx:(Math.random()-.5)*4,vy:-(1+Math.random()*2),life:1,size:2+Math.random()*4});}

  // Hose angle
  let hoseAngle=0;
  // Refill bucket positions
  const REFILLS=[{x:60,y:GROUND-18},{x:420,y:GROUND-18}];

  function loop(){
    frame++;
    if(!gameWon&&!gameOver){
      // Movement
      if(keys['ArrowLeft']||keys['KeyA'])pvx=Math.max(pvx-1.1,-6);
      else if(keys['ArrowRight']||keys['KeyD'])pvx=Math.min(pvx+1.1,6);
      else pvx*=0.72;
      px=Math.max(30,Math.min(W-30,px+pvx));

      // Hose aim
      hoseAngle=Math.atan2(mouseY-(GROUND-30),mouseX-px);

      // Water refill
      REFILLS.forEach(r=>{if(Math.abs(px-r.x)<30&&water<100){water=Math.min(100,water+1.5);}});

      // Spray
      if(spraying&&water>0){
        water=Math.max(0,water-.6);
        for(let i=0;i<5;i++){
          const spread=(Math.random()-.5)*0.25;
          const spd=9+Math.random()*5;
          waterParticles.push({x:px+Math.cos(hoseAngle)*18,y:GROUND-30+Math.sin(hoseAngle)*18,vx:Math.cos(hoseAngle+spread)*spd,vy:Math.sin(hoseAngle+spread)*spd,life:1,size:5+Math.random()*3,age:0});
        }
      }

      // Water physics
      for(let i=waterParticles.length-1;i>=0;i--){
        const w=waterParticles[i];w.x+=w.vx;w.y+=w.vy;w.vy+=0.38;w.life-=0.022;w.age++;
        if(w.life<=0||w.y>H){waterParticles.splice(i,1);continue;}
        // Hit fires
        let hit=false;
        firespots.forEach((spot,si)=>{
          if(spot.out||hit)return;
          if(w.x>spot.x&&w.x<spot.x+spot.w&&w.y>spot.y-5&&w.y<spot.y+spot.h){
            spot.health-=2.5;w.life=0;hit=true;
            spawnSteam(w.x,w.y,2);
            if(spot.health<=0){spot.health=0;spot.out=true;firePool[si]=[];earned+=20;score++;spawnSteam(spot.x+spot.w/2,spot.y+spot.h/2,8);spawnAsh(spot.x+spot.w/2,spot.y);water=Math.min(100,water+15);// reward water for putting out fire
            }
          }
        });
      }

      // Fire particles
      firespots.forEach((spot,si)=>{
        if(spot.out)return;
        if(Math.random()<0.35+spot.intensity*0.35)spawnFirePart(spot);
        // Heat damage
        const dx=px-(spot.x+spot.w/2),dy=GROUND-30-(spot.y+spot.h/2);
        const dist=Math.sqrt(dx*dx+dy*dy);
        if(dist<100){hp-=0.06*(1-dist/100)*spot.intensity;}
        // Fire update
        for(let i=firePool[si].length-1;i>=0;i--){
          const p=firePool[si][i];p.x+=p.vx;p.y+=p.vy;p.vy+=0.05;p.life-=0.015;p.size*=0.997;
          if(p.life<=0)firePool[si].splice(i,1);
        }
      });

      for(let i=steamParticles.length-1;i>=0;i--){const s=steamParticles[i];s.x+=s.vx;s.y+=s.vy;s.life-=0.018;if(s.life<=0)steamParticles.splice(i,1);}
      for(let i=ashParticles.length-1;i>=0;i--){const a=ashParticles[i];a.x+=a.vx;a.y+=a.vy;a.vy+=0.06;a.life-=0.025;if(a.life<=0)ashParticles.splice(i,1);}
      earned=Math.min(earned,200);

      if(firespots.every(s=>s.out)){gameWon=true;earned=Math.min(earned+60,240);showWin('🚒 CASINO SAVED! 🎉');cBurst(area,22,'#00ff88');}
      if(hp<=0){gameOver=true;}
    }

    // ── DRAW ──
    ctx.fillStyle='#0a0a14';ctx.fillRect(0,0,W,H);
    // Night sky with smoke haze
    const smokeAmt=1-firespots.filter(s=>s.out).length/firespots.length;
    ctx.fillStyle=`rgba(60,20,0,${smokeAmt*0.35})`;ctx.fillRect(0,0,W,H);

    // Background city silhouette
    ctx.fillStyle='rgba(20,5,5,0.8)';
    for(let i=0;i<5;i++){const bx=i*90+10;const bh=50+((i*47)%70);ctx.fillRect(bx,BLDG_TOP-bh-30,60+((i*13)%30),bh+30);}

    mgHeader(ctx,W,earned,'← → move · Hold mouse to spray · Buckets refill water!');

    // Casino building floors
    for(let f=0;f<FLOORS;f++){
      const fy=BLDG_TOP+f*FLOOR_H;
      const floorGrad=ctx.createLinearGradient(BLDG_LEFT,fy,BLDG_RIGHT,fy);
      floorGrad.addColorStop(0,'#1a0a05');floorGrad.addColorStop(0.5,'#2a1208');floorGrad.addColorStop(1,'#1a0a05');
      ctx.fillStyle=floorGrad;ctx.fillRect(BLDG_LEFT,fy,BLDG_RIGHT-BLDG_LEFT,FLOOR_H);
      ctx.strokeStyle='rgba(255,200,100,0.12)';ctx.lineWidth=1;ctx.strokeRect(BLDG_LEFT,fy,BLDG_RIGHT-BLDG_LEFT,FLOOR_H);
      // Floor label
      ctx.fillStyle='rgba(255,200,100,0.25)';ctx.font='8px Cinzel';ctx.textAlign='left';ctx.fillText('FLOOR '+(FLOORS-f),BLDG_LEFT+6,fy+FLOOR_H-6);
    }
    // Roof
    ctx.fillStyle='#0f0804';ctx.fillRect(BLDG_LEFT-5,BLDG_TOP-15,BLDG_RIGHT-BLDG_LEFT+10,15);
    ctx.fillStyle='rgba(255,215,0,0.6)';ctx.font='bold 11px Cinzel';ctx.textAlign='center';ctx.fillText('✦ LUCKY STAR GRAND CASINO ✦',W/2,BLDG_TOP-3);

    // Windows (unburnt = normal, burning = orange glow)
    firespots.forEach(spot=>{
      if(spot.out){
        ctx.fillStyle='rgba(80,80,80,0.4)';ctx.fillRect(spot.x,spot.y,spot.w,spot.h*0.7);
        ctx.strokeStyle='rgba(100,100,100,0.3)';ctx.lineWidth=1;ctx.strokeRect(spot.x,spot.y,spot.w,spot.h*0.7);
        // Char marks
        ctx.fillStyle='rgba(0,0,0,0.5)';ctx.font='14px serif';ctx.textAlign='center';ctx.fillText('💨',spot.x+spot.w/2,spot.y+spot.h*.5);
      } else {
        const glow=0.5+Math.sin(frame*0.1+spot.x)*0.3;
        ctx.fillStyle=`rgba(255,${80+spot.health*.8|0},0,${0.3+glow*0.3})`;ctx.fillRect(spot.x,spot.y,spot.w,spot.h*.7);
        ctx.strokeStyle=`rgba(255,150,0,${glow*0.8})`;ctx.lineWidth=2;ctx.strokeRect(spot.x,spot.y,spot.w,spot.h*.7);
        // Health bar on window
        ctx.fillStyle='rgba(0,0,0,0.5)';ctx.fillRect(spot.x,spot.y+spot.h*.7+2,spot.w,4);
        const hcol=spot.health>60?'#ff4400':spot.health>30?'#ff8800':'#ff0000';
        ctx.fillStyle=hcol;ctx.fillRect(spot.x,spot.y+spot.h*.7+2,spot.w*(spot.health/100),4);
      }
    });

    // Fire particles
    firespots.forEach((spot,si)=>{
      firePool[si].forEach(p=>{
        const alpha=p.life;
        const fg=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.size);
        fg.addColorStop(0,`hsla(60,100%,90%,${alpha})`);fg.addColorStop(.3,`hsla(${p.hue},100%,55%,${alpha*.9})`);fg.addColorStop(1,'transparent');
        ctx.fillStyle=fg;ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,Math.PI*2);ctx.fill();
      });
    });

    // Steam
    steamParticles.forEach(s=>{ctx.save();ctx.globalAlpha=s.life*.5;const sg=ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,s.size);sg.addColorStop(0,'rgba(200,220,255,0.8)');sg.addColorStop(1,'transparent');ctx.fillStyle=sg;ctx.beginPath();ctx.arc(s.x,s.y,s.size,0,Math.PI*2);ctx.fill();ctx.restore();});

    // Ash
    ashParticles.forEach(a=>{ctx.globalAlpha=a.life*.6;ctx.fillStyle='#555';ctx.beginPath();ctx.arc(a.x,a.y,a.size,0,Math.PI*2);ctx.fill();});ctx.globalAlpha=1;

    // Ground / street
    ctx.fillStyle='#0d0d1a';ctx.fillRect(0,GROUND,W,H-GROUND);
    ctx.strokeStyle='rgba(255,215,0,0.15)';ctx.lineWidth=2;ctx.setLineDash([18,14]);ctx.beginPath();ctx.moveTo(0,GROUND+18);ctx.lineTo(W,GROUND+18);ctx.stroke();ctx.setLineDash([]);

    // Water bucket refill stations
    REFILLS.forEach(r=>{
      ctx.fillStyle='#1144aa';ctx.beginPath();if(ctx.roundRect)ctx.roundRect(r.x-16,r.y-16,32,20,4);else ctx.rect(r.x-16,r.y-16,32,20);ctx.fill();
      ctx.fillStyle='rgba(100,200,255,0.7)';ctx.beginPath();if(ctx.roundRect)ctx.roundRect(r.x-14,r.y-14,28,8,2);else ctx.rect(r.x-14,r.y-14,28,8);ctx.fill();
      ctx.fillStyle='#88ccff';ctx.font='10px Cinzel';ctx.textAlign='center';ctx.fillText('💧WATER',r.x,r.y+4);
      const near=Math.abs(px-r.x)<30;if(near){ctx.strokeStyle='rgba(100,200,255,0.6)';ctx.lineWidth=2;ctx.setLineDash([3,3]);ctx.strokeRect(r.x-18,r.y-18,36,24);ctx.setLineDash([]);}
    });

    // Water particles
    waterParticles.forEach(w=>{
      ctx.save();ctx.globalAlpha=w.life;
      const wg=ctx.createRadialGradient(w.x,w.y,0,w.x,w.y,w.size);
      wg.addColorStop(0,'rgba(150,220,255,1)');wg.addColorStop(1,'rgba(50,130,255,0)');
      ctx.fillStyle=wg;ctx.beginPath();ctx.arc(w.x,w.y,w.size,0,Math.PI*2);ctx.fill();ctx.restore();
    });

    // Firefighter player
    const py2=GROUND-52;
    ctx.save();ctx.translate(px,py2);
    // Shadow
    ctx.fillStyle='rgba(0,0,0,0.3)';ctx.beginPath();ctx.ellipse(0,54,16,5,0,0,Math.PI*2);ctx.fill();
    // Legs
    ctx.fillStyle='#cc5500';const legS=pvx!==0?Math.sin(frame*0.4)*10:0;
    ctx.fillRect(-12,34+legS,10,20);ctx.fillRect(2,34-legS,10,20);
    // Body / suit
    const ffGrad=ctx.createLinearGradient(-14,0,14,0);ffGrad.addColorStop(0,'#cc4400');ffGrad.addColorStop(1,'#ff6600');
    ctx.fillStyle=ffGrad;ctx.beginPath();if(ctx.roundRect)ctx.roundRect(-14,6,28,30,4);else ctx.fillRect(-14,6,28,30);ctx.fill();
    // Reflective strips
    ctx.fillStyle='rgba(255,255,150,0.7)';ctx.fillRect(-14,18,28,3);ctx.fillRect(-14,26,28,3);
    // Arm with hose
    const hx=Math.cos(hoseAngle)*28,hy=Math.sin(hoseAngle)*28;
    ctx.strokeStyle='#666';ctx.lineWidth=4;ctx.beginPath();ctx.moveTo(4,18);ctx.lineTo(14,24);ctx.stroke();
    ctx.strokeStyle='#888';ctx.lineWidth=5;ctx.lineCap='round';ctx.beginPath();ctx.moveTo(10,22);ctx.lineTo(10+hx*.5,22+hy*.5);ctx.stroke();ctx.lineCap='butt';
    // Nozzle
    ctx.fillStyle='#555';ctx.save();ctx.translate(10+hx*.5,22+hy*.5);ctx.rotate(hoseAngle);
    ctx.fillRect(0,-3,16,6);ctx.fillStyle='#444';ctx.fillRect(14,-4,8,8);ctx.restore();
    // Head with helmet
    ctx.fillStyle='#e8c090';ctx.beginPath();ctx.arc(0,-6,12,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#cc3300';ctx.beginPath();ctx.arc(0,-8,13,Math.PI+.3,0-.3);ctx.fill();
    ctx.fillRect(-12,-8,24,5);
    // Visor
    ctx.fillStyle='rgba(200,230,255,0.5)';ctx.beginPath();ctx.arc(0,-4,9,0.2,Math.PI-.2);ctx.fill();
    // Eyes
    ctx.fillStyle='#222';ctx.beginPath();ctx.arc(-4,-8,2.5,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.arc(4,-8,2.5,0,Math.PI*2);ctx.fill();
    if(spraying&&water>0){// spray arc preview
      ctx.strokeStyle='rgba(100,200,255,0.25)';ctx.lineWidth=2;ctx.setLineDash([4,6]);
      ctx.beginPath();ctx.moveTo(10+hx*.5,22+hy*.5);ctx.lineTo(10+hx*1.5,22+hy*1.5);ctx.stroke();ctx.setLineDash([]);}
    ctx.restore();

    // HUD bars
    // Heat / HP
    ctx.fillStyle='rgba(0,0,0,0.55)';ctx.beginPath();if(ctx.roundRect)ctx.roundRect(14,112,145,9,5);else ctx.rect(14,112,145,9);ctx.fill();
    const hpCol=hp>60?'#2ecc71':hp>30?'#e67e22':'#e74c3c';
    ctx.fillStyle=hpCol;ctx.beginPath();if(ctx.roundRect)ctx.roundRect(14,112,145*(hp/100),9,5);else ctx.rect(14,112,145*(hp/100),9);ctx.fill();
    ctx.fillStyle='rgba(255,255,255,0.55)';ctx.font='8px Cinzel';ctx.textAlign='left';ctx.fillText('🌡️ HEAT DANGER',16,110);
    // Water tank
    ctx.fillStyle='rgba(0,0,0,0.55)';ctx.beginPath();if(ctx.roundRect)ctx.roundRect(170,112,145,9,5);else ctx.rect(170,112,145,9);ctx.fill();
    ctx.fillStyle='#4499ff';ctx.beginPath();if(ctx.roundRect)ctx.roundRect(170,112,145*(water/100),9,5);else ctx.rect(170,112,145*(water/100),9);ctx.fill();
    ctx.fillStyle='rgba(255,255,255,0.55)';ctx.textAlign='left';ctx.fillText('💧 WATER TANK',172,110);
    // Fires left
    const firesLeft=firespots.filter(s=>!s.out).length;
    ctx.fillStyle='rgba(255,100,0,0.9)';ctx.font='bold 12px Cinzel';ctx.textAlign='right';ctx.fillText('🔥 '+firesLeft+' fires left',W-14,113);

    // Win/Lose overlays
    if(gameWon){
      ctx.fillStyle='rgba(0,20,0,0.9)';ctx.fillRect(0,0,W,H);
      ctx.fillStyle='#2ecc71';ctx.shadowColor='#2ecc71';ctx.shadowBlur=28;ctx.font='bold 34px Cinzel';ctx.textAlign='center';ctx.fillText('CASINO SAVED!',W/2,H/2-50);ctx.shadowBlur=0;
      ctx.fillStyle='rgba(255,255,255,0.8)';ctx.font='16px Nunito';ctx.fillText('All '+score+' fires extinguished! 🎉',W/2,H/2-12);
      ctx.fillStyle='#FFD700';ctx.font='bold 18px Nunito';ctx.fillText((window._savingCasino?'Reward: ':'Earned: ')+'\uD83E\uDE99'+earned,W/2,H/2+26);
      const pulse=Math.sin(Date.now()/400)*.12+.88;ctx.fillStyle=`rgba(16,185,129,${pulse})`;ctx.beginPath();if(ctx.roundRect)ctx.roundRect(W/2-110,H-46,220,30,8);else ctx.rect(W/2-110,H-46,220,30);ctx.fill();ctx.fillStyle='#fff';ctx.font='bold 13px Cinzel';ctx.fillText(window._savingCasino?'CLAIM REWARD & RETURN 🏆':'RETURN TO CASINO 🎰',W/2,H-25);
    }
    if(gameOver){
      ctx.fillStyle='rgba(60,0,0,0.9)';ctx.fillRect(0,0,W,H);
      ctx.fillStyle='#ff3333';ctx.shadowColor='#ff0000';ctx.shadowBlur=20;ctx.font='bold 30px Cinzel';ctx.textAlign='center';ctx.fillText('OVERCOME BY HEAT!',W/2,H/2-48);ctx.shadowBlur=0;
      ctx.fillStyle='rgba(255,200,100,0.7)';ctx.font='15px Nunito';ctx.fillText('The casino burned down...',W/2,H/2-10);
      if(window._savingCasino){
        ctx.fillStyle='rgba(255,100,50,0.9)';ctx.font='bold 14px Cinzel';ctx.fillText('Click to lose everything & rebuild',W/2,H/2+30);
      } else {
        ctx.fillStyle='#FFD700';ctx.font='bold 17px Nunito';ctx.fillText('Earned: \uD83E\uDE99'+earned,W/2,H/2+25);
        if(earned>0)mgReturnBtn(ctx,W,H,earned);
        ctx.fillStyle='rgba(255,255,255,0.35)';ctx.font='13px Cinzel';ctx.fillText('Click to try again',W/2,H/2+65);
      }
    }

    activeLoop=requestAnimationFrame(loop);
  }
  area._cleanup=()=>{document.removeEventListener('keydown',kd);document.removeEventListener('keyup',ku);};
  loop();
}



