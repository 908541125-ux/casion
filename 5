    ctx.beginPath();ctx.arc(cx,cy,18,0,Math.PI*2);ctx.fillStyle=hg;ctx.fill();
    ctx.strokeStyle='rgba(255,215,0,.6)';ctx.lineWidth=2;ctx.stroke();
    ctx.fillStyle='rgba(255,215,0,.7)';ctx.font='bold 8px Nunito';ctx.textAlign='center';ctx.fillText('★',cx,cy+3);
