/* SCRATCH */
.scratch-wrap{width:100%;max-width:420px;display:flex;flex-direction:column;align-items:center;gap:15px}
.scratch-card{width:100%;background:linear-gradient(145deg,#ccc,#a0a0a0);border-radius:16px;padding:5px;box-shadow:0 10px 30px rgba(0,0,0,.5)}
