/* WIN OVERLAY */
#winOv{position:fixed;inset:0;z-index:5000;pointer-events:none;display:flex;align-items:center;justify-content:center}
.win-banner{font-family:'Cinzel Decorative',serif;font-size:clamp(28px,5.5vw,60px);color:var(--gold);text-align:center;text-shadow:0 0 60px rgba(255,215,0,.8);opacity:0;transform:scale(.4);transition:all .38s;padding:18px 36px;background:rgba(0,0,0,.8);border:2px solid rgba(255,215,0,.45);border-radius:18px;backdrop-filter:blur(12px)}
.win-banner.show{opacity:1;transform:scale(1)}
.win-banner.gone{opacity:0;transform:scale(1.6)}

/* FX + TOAST */
#fx{position:fixed;inset:0;pointer-events:none;z-index:4999;overflow:hidden}
.pt{position:absolute;border-radius:50%;animation:ptFly var(--d,.8s) ease-out forwards}
@keyframes ptFly{0%{opacity:1;transform:translate(0,0) scale(1) rotate(0)}100%{opacity:0;transform:translate(var(--tx,0),var(--ty,-100px)) scale(0) rotate(360deg)}}
#toast{position:fixed;bottom:26px;left:50%;transform:translateX(-50%) translateY(80px);background:rgba(0,0,0,.92);border:1px solid rgba(255,215,0,.25);color:var(--gold);padding:11px 22px;border-radius:50px;font-family:'Cinzel',serif;font-size:12px;letter-spacing:2px;z-index:6000;transition:transform .35s;backdrop-filter:blur(14px);white-space:nowrap}
#toast.show{transform:translateX(-50%) translateY(0)}

/* COIN RAIN */
.coin-rain{position:fixed;top:0;font-size:22px;pointer-events:none;z-index:4998;animation:coinRain var(--dur,2s) linear forwards}
@keyframes coinRain{0%{transform:translateY(-40px) rotate(0deg);opacity:1}100%{transform:translateY(110vh) rotate(720deg);opacity:.2}}

/* SHAKE ANIMATION */
.shake{animation:shake .5s ease-in-out}
@keyframes shake{0%,100%{transform:translateX(0)}15%{transform:translateX(-10px)}30%{transform:translateX(10px)}45%{transform:translateX(-8px)}60%{transform:translateX(8px)}75%{transform:translateX(-5px)}90%{transform:translateX(5px)}}

@media(max-width:480px){.reel{width:75px;height:87px;font-size:44px}.vpc{width:55px;height:80px}.die{width:67px;height:67px}.hilo-card{width:110px;height:146px}}
</style>
</head>
