  function renderH(){const el=area.querySelector('#vpc');el.innerHTML='';hand.forEach((c,i)=>{const red=c.s==='♥'||c.s==='♦';const div=document.createElement('div');div.className=`vpc${red?' rv':''}${held[i]?' held':''}`;div.innerHTML=`<div class="vr">${c.r}</div><div class="vs">${c.s}</div>${held[i]?'<div class="hold-tag">HELD</div>':''}`;div.onclick=()=>{if(phase==='hold'){held[i]=!held[i];renderH();}};el.appendChild(div);});}
