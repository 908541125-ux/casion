// JEREMY WALKS IN
// ════════════════════════════════════════════
function jeremyWalkIn(){
  // Close any open game
  stopLoop();
  document.getElementById('screen').classList.remove('on');
  document.getElementById('lobby').style.display='flex';
  document.getElementById('debtTimer').style.display='none';

  // Create fullscreen canvas overlay
  const ov=document.createElement('div');
  ov.id='jeremyOverlay';
  ov.style.cssText='position:fixed;inset:0;z-index:9000;background:rgba(0,0,0,0);pointer-events:all;';
  const cv=document.createElement('canvas');
  cv.width=window.innerWidth;cv.height=window.innerHeight;
  cv.style.cssText='position:absolute;inset:0;width:100%;height:100%;';
  ov.appendChild(cv);
  document.body.appendChild(ov);

  const W=cv.width,H=cv.height;
  const ctx=cv.getContext('2d');
  const GROUND=H;
  const JEREMY_W=90,JEREMY_H=140;

  // Jeremy walks in from the right edge
  let jx=W+JEREMY_W;
  const targetX=W*0.5;  // walk to center
  let walkFrame=0;
  let phase='walkin';  // walkin -> talk -> done
  let talkTimer=0;
  const speeches=["WHERE'S MY MONEY?","YOU'RE LATE.","BIG MISTAKE.","BURN IT DOWN."];
  let speechIdx=0;
  let speechTimer=0;
  let af2=null;
  // Dim the bg gradually
  let bgAlpha=0;

  function drawJeremy(x,legPhase){
    const tls=Math.sin(legPhase)*18;
    ctx.save();ctx.translate(x, GROUND-JEREMY_H-20);
    // Shadow
    ctx.fillStyle='rgba(0,0,0,0.4)';ctx.beginPath();ctx.ellipse(JEREMY_W/2,JEREMY_H+10,50,12,0,0,Math.PI*2);ctx.fill();
    // Legs
    ctx.fillStyle='#111';
    ctx.fillRect(JEREMY_W/2-28,JEREMY_H-20+tls,22,40);
    ctx.fillRect(JEREMY_W/2+6,JEREMY_H-20-tls,22,40);
    // Suit body
    const sg=ctx.createLinearGradient(0,0,JEREMY_W,0);
    sg.addColorStop(0,'#1a0a00');sg.addColorStop(1,'#3a1a00');
    ctx.fillStyle=sg;
    ctx.beginPath();if(ctx.roundRect)ctx.roundRect(JEREMY_W/2-32,JEREMY_H-90,64,72,8);else ctx.fillRect(JEREMY_W/2-32,JEREMY_H-90,64,72);
    ctx.fill();
    // Pinstripes
    ctx.strokeStyle='rgba(255,215,0,0.18)';ctx.lineWidth=1.5;
    for(let s=0;s<5;s++){ctx.beginPath();ctx.moveTo(JEREMY_W/2-26+s*14,JEREMY_H-90);ctx.lineTo(JEREMY_W/2-26+s*14,JEREMY_H-18);ctx.stroke();}
    // Shirt
    ctx.fillStyle='#f0e8d0';ctx.fillRect(JEREMY_W/2-9,JEREMY_H-88,18,42);
    // Tie
    ctx.fillStyle='#cc0000';ctx.beginPath();ctx.moveTo(JEREMY_W/2-5,JEREMY_H-86);ctx.lineTo(JEREMY_W/2,JEREMY_H-54);ctx.lineTo(JEREMY_W/2+5,JEREMY_H-86);ctx.fill();
    // Arms - one raised menacingly
    ctx.fillStyle='#1a0a00';
    ctx.save();ctx.translate(JEREMY_W/2-32,JEREMY_H-80);ctx.rotate(-0.3+Math.sin(legPhase*0.5)*0.1);ctx.fillRect(-8,0,14,44);ctx.restore();
    ctx.save();ctx.translate(JEREMY_W/2+18,JEREMY_H-80);ctx.rotate(0.6+Math.sin(legPhase*0.5)*0.15);ctx.fillRect(-6,0,14,38);ctx.restore();
    // Head
    ctx.fillStyle='#d4a060';ctx.beginPath();ctx.arc(JEREMY_W/2,JEREMY_H-110,30,0,Math.PI*2);ctx.fill();
    // Double chin
    ctx.fillStyle='#c89050';ctx.beginPath();ctx.ellipse(JEREMY_W/2,JEREMY_H-85,18,10,0,0,Math.PI*2);ctx.fill();
    // Eyes - ANGRY
    ctx.fillStyle='#111';ctx.beginPath();ctx.arc(JEREMY_W/2-11,JEREMY_H-118,5,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(JEREMY_W/2+11,JEREMY_H-118,5,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#ff0000';ctx.beginPath();ctx.arc(JEREMY_W/2-11,JEREMY_H-118,2.5,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(JEREMY_W/2+11,JEREMY_H-118,2.5,0,Math.PI*2);ctx.fill();
    // Angry brows
    ctx.strokeStyle='#4a0000';ctx.lineWidth=3;
    ctx.beginPath();ctx.moveTo(JEREMY_W/2-17,JEREMY_H-126);ctx.lineTo(JEREMY_W/2-5,JEREMY_H-122);ctx.stroke();
    ctx.beginPath();ctx.moveTo(JEREMY_W/2+17,JEREMY_H-126);ctx.lineTo(JEREMY_W/2+5,JEREMY_H-122);ctx.stroke();
    // Scar
    ctx.strokeStyle='#8B0000';ctx.lineWidth=2;
    ctx.beginPath();ctx.moveTo(JEREMY_W/2+8,JEREMY_H-128);ctx.lineTo(JEREMY_W/2+16,JEREMY_H-114);ctx.stroke();
    // Mouth — grimace
    ctx.strokeStyle='#4a0000';ctx.lineWidth=2.5;
    ctx.beginPath();ctx.moveTo(JEREMY_W/2-8,JEREMY_H-100);ctx.lineTo(JEREMY_W/2+8,JEREMY_H-100);ctx.stroke();
    // Fedora
    ctx.fillStyle='#111';ctx.fillRect(JEREMY_W/2-28,JEREMY_H-148,56,15);
    ctx.beginPath();if(ctx.roundRect)ctx.roundRect(JEREMY_W/2-18,JEREMY_H-164,36,18,4);else ctx.fillRect(JEREMY_W/2-18,JEREMY_H-164,36,18);ctx.fill();
    ctx.fillStyle='rgba(255,215,0,0.7)';ctx.fillRect(JEREMY_W/2-28,JEREMY_H-133,56,4);
    // Cigar
    ctx.fillStyle='#c8a060';ctx.fillRect(JEREMY_W/2+8,JEREMY_H-101,22,5);
    ctx.fillStyle='#ff6600';ctx.beginPath();ctx.arc(JEREMY_W/2+30,JEREMY_H-99,5,0,Math.PI*2);ctx.fill();
    // Glow around him
    const glow=ctx.createRadialGradient(JEREMY_W/2,JEREMY_H/2,10,JEREMY_W/2,JEREMY_H/2,120);
    glow.addColorStop(0,'rgba(200,0,0,0.08)');glow.addColorStop(1,'transparent');
    ctx.fillStyle=glow;ctx.beginPath();ctx.arc(JEREMY_W/2,JEREMY_H/2,120,0,Math.PI*2);ctx.fill();
    ctx.restore();
  }

  function loop(){
    ctx.clearRect(0,0,W,H);
    // Dark overlay
    if(bgAlpha<0.75)bgAlpha+=0.015;
    ctx.fillStyle=`rgba(0,0,0,${bgAlpha})`;ctx.fillRect(0,0,W,H);

    walkFrame++;

    if(phase==='walkin'){
      // Walk in fast from the right
      jx-=12;
      if(jx<=targetX){jx=targetX;phase='talk';talkTimer=0;speechTimer=0;}
      drawJeremy(jx, walkFrame*0.18);
      // Screen shake as he approaches
      if(Math.random()<0.3){ctx.save();ctx.translate((Math.random()-.5)*6,(Math.random()-.5)*3);drawJeremy(jx,walkFrame*0.18);ctx.restore();}
    } else if(phase==='talk'){
      talkTimer++;
      // Jeremy stands and talks
      drawJeremy(jx, Math.sin(walkFrame*0.06)*0.2); // slight sway
      // Rotating speech bubbles
      if(talkTimer%80===1)speechIdx=(speechIdx+1)%speeches.length;
      speechTimer++;

      const lbl=speeches[speechIdx];
      const bx=jx+JEREMY_W/2+30;
      const by=GROUND-JEREMY_H-60;
      ctx.font='bold 18px Cinzel';
      const tw=ctx.measureText(lbl).width+24;
      // bubble
      ctx.fillStyle='rgba(255,220,40,0.96)';ctx.strokeStyle='#8B0000';ctx.lineWidth=2.5;
      ctx.beginPath();if(ctx.roundRect)ctx.roundRect(bx,by,tw,34,10);else ctx.rect(bx,by,tw,34);ctx.fill();ctx.stroke();
      // tail
      ctx.beginPath();ctx.moveTo(bx,by+17);ctx.lineTo(bx-14,by+26);ctx.lineTo(bx,by+28);ctx.fill();
      ctx.fillStyle='#7a0000';ctx.textAlign='left';ctx.fillText(lbl,bx+12,by+23);

      // Red pulsing vignette
      const pulse=Math.abs(Math.sin(walkFrame*0.06))*0.25;
      const vg=ctx.createRadialGradient(W/2,H/2,H*0.3,W/2,H/2,H*0.8);
      vg.addColorStop(0,'transparent');vg.addColorStop(1,`rgba(180,0,0,${pulse})`);
      ctx.fillStyle=vg;ctx.fillRect(0,0,W,H);

      if(talkTimer>180){phase='done';}
    } else {
      // Done — trigger burn
      ov.remove();
      burnCasino();
      return;
    }

    af2=requestAnimationFrame(loop);
  }
  loop();
}


let fireAnimLoop=null;
function burnCasino(){
  loanDebt=0;loanAmount=0;clearInterval(loanTimer);loanTimer=null;
  document.getElementById('debtTimer').style.display='none';
  stopLoop();
  // Hide game screen if open, show lobby behind fire
  document.getElementById('screen').classList.remove('on');
  document.getElementById('lobby').style.display='flex';
  const ov=document.getElementById('fireOverlay');
  ov.style.display='block';
  document.getElementById('fireTextPanel').style.display='flex';
  const cv=document.getElementById('fireCanvas');
  cv.width=innerWidth;cv.height=innerHeight;
  const ctx=cv.getContext('2d');
  const particles=[];
  const W=cv.width,H=cv.height;
  function spawnFire(){
    for(let i=0;i<8;i++){
      particles.push({
        x:Math.random()*W,y:H+20,
        vx:(Math.random()-.5)*3,vy:-(2+Math.random()*6),
        life:1,maxLife:1,
        size:8+Math.random()*20,
        hue:Math.random()<.5?20:40
      });
    }
  }
  let frame=0;
  function fireLoop(){
    ctx.fillStyle='rgba(0,0,0,0.12)';ctx.fillRect(0,0,W,H);
    spawnFire();
    for(let i=particles.length-1;i>=0;i--){
      const p=particles[i];
      p.x+=p.vx;p.y+=p.vy;p.vy+=0.05;p.life-=0.012;p.size*=0.995;
      if(p.life<=0){particles.splice(i,1);continue;}
      const alpha=p.life;
      const g=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.size);
      g.addColorStop(0,`hsla(60,100%,80%,${alpha})`);
      g.addColorStop(.4,`hsla(${p.hue},100%,50%,${alpha*.8})`);
      g.addColorStop(1,'transparent');
      ctx.fillStyle=g;ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,Math.PI*2);ctx.fill();
    }
    if(frame%4===0){particles.push({x:Math.random()*W,y:H*.3+Math.random()*H*.4,vx:(Math.random()-.5)*1.5,vy:-(0.5+Math.random()),life:.3,maxLife:.3,size:30+Math.random()*60,isSmoke:true});}
    particles.filter(p=>p.isSmoke).forEach(p=>{
      const g=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.size);
      g.addColorStop(0,`rgba(40,40,40,${p.life*.4})`);g.addColorStop(1,'transparent');
      ctx.fillStyle=g;ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,Math.PI*2);ctx.fill();
    });
    frame++;fireAnimLoop=requestAnimationFrame(fireLoop);
  }
  fireLoop();
  try{
    const ac=new AudioContext();
    const buf=ac.createBuffer(1,ac.sampleRate*2,ac.sampleRate);
    const d=buf.getChannelData(0);
    for(let i=0;i<d.length;i++)d[i]=(Math.random()*2-1)*Math.max(0,1-i/d.length);
    const src=ac.createBufferSource();src.buffer=buf;
    const g=ac.createGain();g.gain.value=.3;
    src.connect(g);g.connect(ac.destination);src.start();
  }catch(e){}
}

