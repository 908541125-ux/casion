function evalPoker(hand){const RO='A23456789TJQKA';const vals=hand.map(c=>RO.indexOf(c.r==='10'?'T':c.r));const suits=hand.map(c=>c.s);const sorted=[...vals].sort((a,b)=>a-b);const cnts={};vals.forEach(v=>cnts[v]=(cnts[v]||0)+1);const grp=Object.values(cnts).sort((a,b)=>b-a);const flush=suits.every(s=>s===suits[0]);const str=sorted[4]-sorted[0]===4&&grp[0]===1;const royalStr=str&&sorted.includes(12)&&sorted.includes(11)&&sorted.includes(10);if(flush&&royalStr)return{name:'Royal Flush',mult:250};if(flush&&str)return{name:'Straight Flush',mult:50};if(grp[0]===4)return{name:'Four of a Kind',mult:25};if(grp[0]===3&&grp[1]===2)return{name:'Full House',mult:9};if(flush)return{name:'Flush',mult:6};if(str)return{name:'Straight',mult:4};if(grp[0]===3)return{name:'Three of a Kind',mult:3};if(grp[0]===2&&grp[1]===2)return{name:'Two Pair',mult:2};if(grp[0]===2){const pv=parseInt(Object.entries(cnts).find(([k,v])=>v===2)[0]);if(pv>=9||pv===0)return{name:'Jacks or Better',mult:1};}return{name:'High Card',mult:0};}

