      ctx.fillStyle=n===0?'#1a8a3a':isRed(n)?'#9b1a1a':'#111';ctx.fill();
      ctx.strokeStyle='rgba(255,215,0,.18)';ctx.lineWidth=.8;ctx.stroke();
