function takeLoan(amount){
  if(loanDebt>0){toast('Pay your current debt first!');return;}
  const rate=LOAN_RATES[amount];
  coins+=amount;loanAmount=amount;loanDebt=rate.back;
  updateHUD();closeSharkModal();
  toast(`+🪙${amount} received! Owe 🪙${rate.back} in ${rate.time}s`);
