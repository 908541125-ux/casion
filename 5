function evalRoulette(num,bt,bet,msg,area){let win=0;const red=isRed(num),even=num%2===0&&num!==0;const col=num===0?'🟢':red?'🔴':'⚫';if(bt==='red'&&red&&num!==0)win=bet*2;else if(bt==='black'&&!red&&num!==0)win=bet*2;else if(bt==='green'&&num===0)win=bet*35;else if(bt==='odd'&&!even&&num!==0)win=bet*2;else if(bt==='even'&&even)win=bet*2;else if(bt==='low'&&num>=1&&num<=18)win=bet*2;else if(bt==='high'&&num>=19)win=bet*2;else if(bt==='dozen1'&&num>=1&&num<=12)win=bet*3;else if(bt==='dozen2'&&num>=13&&num<=24)win=bet*3;else if(bt==='num-'+num)win=bet*35;coins+=win;updateHUD();setTimeout(()=>{msg.textContent=`${num} ${col} — `+(win?`Win! +🪙${win}`:'No win');msg.className='msg-box '+(win?'msg-win':'msg-lose');msg.classList.add('pop');if(win){totalWins++;cBurst(area,win>=bet*10?22:10,win>=bet*20?'#00ffff':'#FFD700');if(win>=bet*10)showWin('🎡 BIG WIN!');}},200);}

