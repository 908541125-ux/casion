  }
  drawWheel(0);
  const msg=area.querySelector('#rm'),spb=area.querySelector('#rspin');
  spb.onclick=()=>{
    if(spinning||!selBet||coins<bet){if(!selBet)toast('Pick a bet first!');if(coins<bet)toast('Not enough coins!');return;}
