<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Lucky Star Grand Casino</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@400;700&family=Nunito:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--gold:#FFD700;--gold2:#FFA500;--dark:#05060d;--red:#c0392b;--card-bg:#f8f3ea;--shark:#1a0a2e}
html,body{height:100%;background:var(--dark);font-family:'Nunito',sans-serif;color:#fff;overflow-x:hidden}

/* ── ANIMATED BG ── */
#bg-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.4}

/* ── FIRE OVERLAY ── */
#fireOverlay{position:fixed;inset:0;z-index:8000;display:none;pointer-events:none}
#fireCanvas{position:absolute;inset:0;width:100%;height:100%}
.fire-text{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;z-index:8001}
.fire-title{font-family:'Cinzel Decorative',serif;font-size:clamp(36px,7vw,80px);color:#ff4500;text-shadow:0 0 40px #ff6600,0 0 80px #ff0000;animation:firePulse 0.4s ease-in-out infinite alternate}
.fire-sub{font-family:'Cinzel',serif;font-size:18px;color:#ffaa00;letter-spacing:3px;margin-top:12px;text-shadow:0 0 20px #ff6600}
@keyframes firePulse{from{transform:translate(-50%,-50%) scale(1)}to{transform:translate(-50%,-50%) scale(1.06)}}
.fire-restart{margin-top:28px;padding:14px 36px;font-family:'Cinzel',serif;font-size:16px;letter-spacing:3px;color:#fff;background:linear-gradient(135deg,#c0392b,#8b0000);border:2px solid rgba(255,100,0,.5);border-radius:12px;cursor:pointer;transition:all .3s;pointer-events:all}
.fire-restart:hover{box-shadow:0 0 30px rgba(255,50,0,.7);transform:scale(1.05)}

/* ── SPLASH ── */
#splash{position:fixed;inset:0;z-index:9999;background:radial-gradient(ellipse at 50% 40%,#0d0d1f,#030408);display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity .8s}
#splash.hide{opacity:0;pointer-events:none}
.sp-stars{font-size:15px;letter-spacing:10px;color:rgba(255,215,0,.3);margin-bottom:12px;animation:fadeUp 1s .2s both}
.sp-title{font-family:'Cinzel Decorative',serif;font-size:clamp(32px,8vw,80px);color:var(--gold);text-align:center;letter-spacing:3px;animation:titleGlow 2s ease-in-out infinite alternate,fadeUp .8s both}
@keyframes titleGlow{from{text-shadow:0 0 20px rgba(255,215,0,.3),0 0 60px rgba(255,150,0,.1)}to{text-shadow:0 0 60px rgba(255,215,0,.9),0 0 120px rgba(255,150,0,.4),0 0 200px rgba(255,100,0,.15)}}
.sp-sub{font-family:'Cinzel',serif;font-size:13px;letter-spacing:10px;color:rgba(255,215,0,.4);margin:8px 0 32px;animation:fadeUp .8s .3s both}
.sp-chips{display:flex;gap:14px;margin-bottom:32px;animation:fadeUp .8s .6s both}
.sp-chip{width:46px;height:46px;border-radius:50%;border:4px solid rgba(255,255,255,.22);position:relative;animation:chipFlip 2.2s ease-in-out infinite}
.sp-chip::after{content:'';position:absolute;inset:5px;border-radius:50%;border:1.5px dashed rgba(255,255,255,.2)}
.sp-chip:nth-child(1){background:radial-gradient(#f05545,#c0392b);animation-delay:0s}
.sp-chip:nth-child(2){background:radial-gradient(#5dade2,#2980b9);animation-delay:.3s}
.sp-chip:nth-child(3){background:radial-gradient(#58d68d,#27ae60);animation-delay:.6s}
.sp-chip:nth-child(4){background:radial-gradient(#c39bd3,#8e44ad);animation-delay:.9s}
.sp-chip:nth-child(5){background:radial-gradient(#ffe08a,#e6a800);animation-delay:1.2s}
@keyframes chipFlip{0%,100%{transform:rotateY(0) scale(1)}50%{transform:rotateY(180deg) scale(.88)}}
.sp-enter{font-family:'Cinzel',serif;font-size:15px;letter-spacing:4px;color:var(--gold);border:2px solid rgba(255,215,0,.5);padding:14px 44px;border-radius:50px;cursor:pointer;background:transparent;transition:all .3s;animation:fadeUp .8s .9s both}
.sp-enter:hover{background:var(--gold);color:#000;box-shadow:0 0 40px rgba(255,215,0,.5);transform:scale(1.04)}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

/* ── LOBBY ── */
#lobby{min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:0 12px 48px;position:relative;z-index:1;opacity:0;transition:opacity .7s}
#lobby.vis{opacity:1}
.ticker-wrap{width:100%;overflow:hidden;background:linear-gradient(90deg,rgba(0,0,0,.9),rgba(255,215,0,.06) 15%,rgba(255,215,0,.06) 85%,rgba(0,0,0,.9));border-bottom:1px solid rgba(255,215,0,.15);padding:7px 0;position:sticky;top:0;z-index:50;backdrop-filter:blur(12px)}
.ticker{white-space:nowrap;display:inline-block;animation:tick 30s linear infinite;font-size:11px;color:rgba(255,215,0,.75);letter-spacing:3px}
@keyframes tick{from{transform:translateX(100vw)}to{transform:translateX(-100%)}}
.hero{padding:28px 0 6px;text-align:center}
.hero-orn{font-size:12px;color:rgba(255,215,0,.2);letter-spacing:12px;margin-bottom:10px}
.casino-name{font-family:'Cinzel Decorative',serif;font-size:clamp(22px,6vw,60px);line-height:1.1;letter-spacing:4px;background:linear-gradient(180deg,#fff9d6 0%,#FFD700 40%,#d4900a 80%,#8B6000 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 28px rgba(255,215,0,.3));animation:nameGlow 5s ease-in-out infinite alternate}
@keyframes nameGlow{from{filter:drop-shadow(0 0 14px rgba(255,215,0,.2))}to{filter:drop-shadow(0 0 48px rgba(255,215,0,.6))}}
.casino-sub{font-family:'Cinzel',serif;font-size:11px;color:rgba(255,215,0,.33);letter-spacing:10px;margin:6px 0 18px;text-transform:uppercase}

/* HUD */
.hud{display:flex;background:rgba(0,0,0,.75);border:1px solid rgba(255,215,0,.18);border-radius:60px;margin-bottom:6px;backdrop-filter:blur(16px);box-shadow:0 4px 30px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.04)}
.hud-item{display:flex;flex-direction:column;align-items:center;padding:10px 20px;position:relative}
.hud-item+.hud-item::before{content:'';position:absolute;left:0;top:20%;height:60%;width:1px;background:rgba(255,215,0,.12)}
.hud-label{font-size:9px;color:rgba(255,255,255,.3);letter-spacing:3px;text-transform:uppercase;margin-bottom:2px}
.hud-val{font-size:16px;font-weight:900;letter-spacing:1px}
.hv-gold{color:var(--gold);text-shadow:0 0 14px rgba(255,215,0,.35);animation:goldPulse 2s ease-in-out infinite alternate}
@keyframes goldPulse{from{text-shadow:0 0 8px rgba(255,215,0,.2)}to{text-shadow:0 0 20px rgba(255,215,0,.6)}}
.hv-silver{color:#bbb}
.hv-green{color:#2ecc71;text-shadow:0 0 12px rgba(46,204,113,.3)}
.hv-red{color:#ff6b6b;text-shadow:0 0 12px rgba(255,107,107,.4);animation:debtPulse .8s ease-in-out infinite alternate}
@keyframes debtPulse{from{text-shadow:0 0 8px rgba(255,50,50,.3)}to{text-shadow:0 0 22px rgba(255,50,50,.8)}}

/* LOAN SHARK BUTTON */
.loan-shark-btn{display:flex;align-items:center;gap:10px;background:linear-gradient(135deg,rgba(80,0,120,.6),rgba(40,0,60,.8));border:1px solid rgba(180,0,255,.3);border-radius:12px;padding:10px 18px;margin-bottom:18px;cursor:pointer;transition:all .3s;font-family:'Cinzel',serif;font-size:13px;color:#cc88ff;letter-spacing:1px;position:relative;overflow:hidden}
.loan-shark-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,0,200,.05),transparent);opacity:0;transition:opacity .3s}
.loan-shark-btn:hover{border-color:rgba(200,0,255,.6);box-shadow:0 0 25px rgba(150,0,255,.3);transform:translateY(-2px)}
.loan-shark-btn:hover::before{opacity:1}
.shark-icon{font-size:24px;animation:sharkFloat 2.5s ease-in-out infinite}
@keyframes sharkFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
.debt-timer{display:flex;align-items:center;gap:8px;background:rgba(200,0,0,.15);border:1px solid rgba(255,50,50,.35);border-radius:10px;padding:8px 16px;margin-bottom:14px;font-family:'Cinzel',serif;font-size:12px;color:#ff6b6b;letter-spacing:1px;animation:debtWarning 1s ease-in-out infinite alternate}
@keyframes debtWarning{from{background:rgba(200,0,0,.1);border-color:rgba(255,50,50,.3)}to{background:rgba(200,0,0,.25);border-color:rgba(255,50,50,.6)}}
.debt-timer-icon{font-size:20px;animation:timerTick 1s steps(1) infinite}
@keyframes timerTick{0%{opacity:1}50%{opacity:.3}}

/* LOAN MODAL */
.modal-overlay{position:fixed;inset:0;z-index:7000;background:rgba(0,0,0,.85);display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);animation:fadeIn .3s ease-out}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.shark-modal{background:linear-gradient(160deg,#120820,#0a0414);border:1px solid rgba(160,0,255,.3);border-radius:20px;padding:28px;max-width:480px;width:90%;position:relative;box-shadow:0 20px 60px rgba(100,0,200,.3),0 0 0 1px rgba(160,0,255,.15);animation:modalSlideUp .35s ease-out}
@keyframes modalSlideUp{from{transform:translateY(40px);opacity:0}to{transform:translateY(0);opacity:1}}
.shark-avatar{font-size:64px;text-align:center;display:block;margin-bottom:12px;animation:sharkFloat 3s ease-in-out infinite}
.shark-name{font-family:'Cinzel Decorative',serif;font-size:22px;color:#cc44ff;text-align:center;margin-bottom:4px;text-shadow:0 0 20px rgba(200,0,255,.4)}
.shark-title{font-family:'Cinzel',serif;font-size:11px;color:rgba(200,150,255,.4);text-align:center;letter-spacing:4px;margin-bottom:18px}
.shark-speech{background:rgba(255,255,255,.04);border:1px solid rgba(200,0,255,.15);border-radius:12px;padding:14px;margin-bottom:18px;font-size:13px;color:rgba(255,230,255,.7);line-height:1.7;font-style:italic}
.loan-options{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.loan-opt{background:rgba(255,255,255,.04);border:1px solid rgba(200,0,255,.2);border-radius:10px;padding:14px;cursor:pointer;text-align:center;transition:all .22s;font-family:'Cinzel',serif}
.loan-opt:hover{border-color:rgba(200,0,255,.6);background:rgba(200,0,255,.1);transform:translateY(-2px);box-shadow:0 6px 20px rgba(150,0,255,.2)}
.loan-amt{font-size:20px;font-weight:900;color:#cc44ff;display:block}
.loan-due{font-size:10px;color:rgba(255,200,255,.4);margin-top:4px;letter-spacing:1px}
.loan-interest{font-size:11px;color:#ff8888;margin-top:2px}
.modal-close{position:absolute;top:14px;right:16px;background:transparent;border:none;color:rgba(255,255,255,.3);font-size:22px;cursor:pointer;transition:color .2s;line-height:1}
.modal-close:hover{color:rgba(255,255,255,.7)}
.repay-section{border-top:1px solid rgba(200,0,255,.15);padding-top:16px}
.repay-info{font-family:'Cinzel',serif;font-size:12px;color:rgba(255,150,150,.7);text-align:center;margin-bottom:10px}

/* SECTION HEADS */
.sec-head{display:flex;align-items:center;gap:14px;width:100%;max-width:1000px;margin:12px 0 11px}
.sec-head::before,.sec-head::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(255,215,0,.25),transparent)}
.sec-head span{font-family:'Cinzel',serif;font-size:11px;color:rgba(255,215,0,.42);letter-spacing:5px;white-space:nowrap}

/* GAME GRID */
.games-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(148px,1fr));gap:10px;width:100%;max-width:1000px}
.game-card{position:relative;border-radius:14px;padding:20px 12px 16px;text-align:center;cursor:pointer;overflow:hidden;transition:transform .22s,box-shadow .22s;background:linear-gradient(160deg,rgba(255,255,255,.055),rgba(255,255,255,.015));border:1px solid rgba(255,215,0,.1)}
.game-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.07),transparent 50%);pointer-events:none}
.game-card::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% -5%,rgba(255,215,0,.1),transparent 70%);opacity:0;transition:opacity .22s}
.game-card:hover{transform:translateY(-6px) scale(1.02);box-shadow:0 18px 44px rgba(0,0,0,.5),0 0 0 1px rgba(255,215,0,.3)}
.game-card:hover::after{opacity:1}
.work-card{border-color:rgba(147,112,219,.14)}
.work-card:hover{box-shadow:0 18px 44px rgba(0,0,0,.5),0 0 0 1px rgba(147,112,219,.38)!important}
.g-icon{font-size:38px;margin-bottom:9px;display:block;filter:drop-shadow(0 3px 8px rgba(0,0,0,.4));transition:transform .22s}
.game-card:hover .g-icon{transform:scale(1.18) translateY(-4px)}
.g-name{font-family:'Cinzel',serif;font-size:12px;color:var(--gold);margin-bottom:4px}
.g-desc{font-size:10px;color:rgba(255,255,255,.34);line-height:1.5}
.badge{position:absolute;top:8px;right:8px;font-size:8px;font-weight:900;padding:2px 6px;border-radius:4px;letter-spacing:1px}
.bn{background:linear-gradient(135deg,#2ecc71,#27ae60)}
.bh{background:linear-gradient(135deg,#e67e22,#d35400)}

/* SCREEN */
#screen{display:none;position:fixed;inset:0;z-index:200;flex-direction:column;overflow:hidden}
#screen.on{display:flex}
.scr-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(255,215,0,.03),transparent 55%),linear-gradient(180deg,#070810,#04050a)}
.scr-hdr{position:relative;z-index:1;display:flex;align-items:center;gap:11px;padding:10px 16px;background:rgba(0,0,0,.82);border-bottom:1px solid rgba(255,215,0,.09);backdrop-filter:blur(20px);flex-shrink:0}
.back-btn{background:rgba(255,215,0,.07);border:1px solid rgba(255,215,0,.22);color:var(--gold);padding:7px 14px;border-radius:8px;cursor:pointer;font-family:'Cinzel',serif;font-size:11px;letter-spacing:1px;transition:all .2s;white-space:nowrap}
.back-btn:hover{background:rgba(255,215,0,.16)}
.scr-title{font-family:'Cinzel Decorative',serif;font-size:15px;color:var(--gold);flex:1;text-align:center;letter-spacing:2px}
.scr-coins{font-size:13px;font-weight:900;color:var(--gold);white-space:nowrap;background:rgba(255,215,0,.07);padding:5px 12px;border-radius:20px;border:1px solid rgba(255,215,0,.18)}
.scr-coins.bump{animation:coinBump .38s ease-out}
@keyframes coinBump{0%,100%{transform:scale(1)}50%{transform:scale(1.22);color:#fff}}
.game-area{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding:13px;overflow-y:auto;gap:9px;position:relative;z-index:1}

/* SHARED COMPONENTS */
.bet-bar{display:flex;align-items:center;gap:8px;background:linear-gradient(135deg,rgba(0,0,0,.65),rgba(255,215,0,.025));border:1px solid rgba(255,215,0,.13);border-radius:12px;padding:8px 13px;flex-wrap:wrap;justify-content:center}
.bet-label{font-size:9px;color:rgba(255,255,255,.3);letter-spacing:3px;text-transform:uppercase}
.bet-val{font-size:18px;font-weight:900;color:var(--gold);min-width:58px;text-align:center}
.chip{width:36px;height:36px;border-radius:50%;cursor:pointer;font-size:10px;font-weight:900;color:#fff;transition:all .14s;font-family:'Nunito',sans-serif;display:flex;align-items:center;justify-content:center;position:relative;box-shadow:0 3px 8px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.2)}
.chip::after{content:'';position:absolute;inset:4px;border-radius:50%;border:1.5px dashed rgba(255,255,255,.22)}
.chip:hover{transform:scale(1.22) translateY(-2px)}
.chip:active{transform:scale(.92)}
.c1{background:radial-gradient(circle at 35% 30%,#f0584a,#c0392b)}
.c5{background:radial-gradient(circle at 35% 30%,#5dade2,#2980b9)}
.c10{background:radial-gradient(circle at 35% 30%,#58d68d,#27ae60)}
.c25{background:radial-gradient(circle at 35% 30%,#c39bd3,#8e44ad)}
.c100{background:radial-gradient(circle at 35% 30%,#f0a347,#e67e22)}
.btn{padding:11px 22px;border-radius:10px;border:none;cursor:pointer;font-family:'Cinzel',serif;font-size:13px;font-weight:700;transition:all .2s;letter-spacing:1px;position:relative;overflow:hidden}
.btn::after{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.14),transparent);transition:left .4s}
.btn:hover::after{left:100%}
.btn:disabled{opacity:.3;cursor:not-allowed;transform:none!important;box-shadow:none!important}
.btn-gold{background:linear-gradient(135deg,#ffe066,#FFD700,#c8a200);color:#000;box-shadow:0 4px 14px rgba(255,215,0,.2)}
.btn-gold:hover:not(:disabled){box-shadow:0 6px 24px rgba(255,215,0,.45);transform:translateY(-2px)}
.btn-red{background:linear-gradient(135deg,#f05545,#e74c3c,#c0392b);color:#fff}
.btn-red:hover:not(:disabled){box-shadow:0 6px 24px rgba(231,76,60,.45);transform:translateY(-2px)}
.btn-green{background:linear-gradient(135deg,#55e88a,#2ecc71,#27ae60);color:#fff}
.btn-green:hover:not(:disabled){box-shadow:0 6px 24px rgba(46,204,113,.45);transform:translateY(-2px)}
.btn-purple{background:linear-gradient(135deg,#cc44ff,#8e44ad);color:#fff}
.btn-purple:hover:not(:disabled){box-shadow:0 6px 24px rgba(142,68,173,.45);transform:translateY(-2px)}
.btn-gray{background:rgba(255,255,255,.07);color:rgba(255,255,255,.6);border:1px solid rgba(255,255,255,.14)}
.btn-gray:hover:not(:disabled){background:rgba(255,255,255,.13);transform:translateY(-1px)}
.msg-box{font-size:18px;font-weight:900;text-align:center;min-height:32px;padding:5px 10px;border-radius:9px;transition:all .25s;letter-spacing:.5px}
.msg-win{color:#2ecc71;text-shadow:0 0 18px rgba(46,204,113,.5);background:rgba(46,204,113,.06)}
.msg-lose{color:#e74c3c;text-shadow:0 0 18px rgba(231,76,60,.5);background:rgba(231,76,60,.06)}
.msg-neutral{color:var(--gold);text-shadow:0 0 12px rgba(255,215,0,.25)}
.msg-info{color:#74b9ff}
.msg-box.pop{animation:pop .38s ease-out}
@keyframes pop{0%{transform:scale(.75);opacity:0}60%{transform:scale(1.07)}100%{transform:scale(1);opacity:1}}

/* SLOTS */
.slots-wrap{background:linear-gradient(160deg,#12122a,#090918);border:1px solid rgba(255,215,0,.22);border-radius:22px;padding:20px;width:100%;max-width:460px;box-shadow:0 20px 60px rgba(0,0,0,.6)}
.slot-lights{display:flex;justify-content:space-around;margin-bottom:13px}
.sl{width:11px;height:11px;border-radius:50%;transition:all .15s}
.reels{display:flex;gap:12px;justify-content:center;margin-bottom:15px}
.reel-wrap{display:flex;flex-direction:column;align-items:center;gap:5px}
.reel{width:90px;height:100px;background:linear-gradient(180deg,#050516,#0c0c20);border-radius:12px;border:2px solid rgba(255,255,255,.07);display:flex;align-items:center;justify-content:center;overflow:hidden;font-size:54px;position:relative;flex-shrink:0;box-shadow:inset 0 4px 14px rgba(0,0,0,.7)}
.reel::before{content:'';position:absolute;top:0;left:0;right:0;height:28%;background:linear-gradient(180deg,rgba(0,0,0,.55),transparent);z-index:1}
.reel::after{content:'';position:absolute;bottom:0;left:0;right:0;height:28%;background:linear-gradient(0deg,rgba(0,0,0,.55),transparent);z-index:1}
.reel.spin{animation:rSpin .09s linear infinite}
.reel.win{border-color:var(--gold);box-shadow:0 0 22px rgba(255,215,0,.55),inset 0 0 18px rgba(255,215,0,.08);animation:reelWin .5s ease-in-out}
@keyframes rSpin{0%{transform:translateY(-11px);opacity:.45}100%{transform:translateY(11px);opacity:.45}}
@keyframes reelWin{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}
.reel-num{font-size:10px;color:rgba(255,215,0,.3);letter-spacing:2px;font-family:'Cinzel',serif}
.payline{display:flex;gap:6px;font-size:11px;flex-wrap:wrap;justify-content:center;font-family:'Cinzel',serif}
.pl-row{background:rgba(255,255,255,.04);padding:4px 10px;border-radius:5px;display:flex;gap:8px;border:1px solid rgba(255,255,255,.05)}
.pl-mul{color:var(--gold);font-weight:700}

/* BJ */
.bj-table{width:100%;max-width:500px;background:radial-gradient(ellipse at 50% 20%,#1c7a40,#0b3c20,#051508);border:1px solid rgba(255,215,0,.18);border-radius:24px;padding:17px;display:flex;flex-direction:column;gap:11px;box-shadow:0 20px 60px rgba(0,0,0,.6)}
.bj-zone{min-height:88px}
.zone-label{font-family:'Cinzel',serif;font-size:9px;color:rgba(255,255,255,.28);letter-spacing:4px;margin-bottom:5px;text-transform:uppercase}
.cards-row{display:flex;gap:7px;flex-wrap:wrap;min-height:78px}
.card{width:55px;height:77px;background:linear-gradient(160deg,#fdf8ef,#ede8df);border-radius:8px;border:1px solid rgba(0,0,0,.1);display:flex;flex-direction:column;align-items:center;justify-content:center;box-shadow:3px 4px 10px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.7);flex-shrink:0;position:relative;animation:cardDeal .28s ease-out}
